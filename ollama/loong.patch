diff --git a/PKGBUILD b/PKGBUILD
index 2c9b8c2..b20e975 100644
--- a/PKGBUILD
+++ b/PKGBUILD
@@ -37,6 +37,9 @@ b2sums=('b9cc2165f8e7cd51f346b1beb24d220a1f820ab9979f3db3359b0869b10950a9b1e3012
         'e8f2b19e2474f30a4f984b45787950012668bf0acb5ad1ebb25cd9776925ab4a6aa927f8131ed53e35b1c71b32c504c700fe5b5145ecd25c7a8284373bb951ed')
 
 build() {
+  # Enable LASX to workaround the compile error with LSX
+  export CFLAGS="${CFLAGS} -mlasx"
+  export CXXFLAGS="${CXXFLAGS} -mlasx"
   export CGO_CPPFLAGS="${CPPFLAGS}"
   export CGO_CFLAGS="${CFLAGS}"
   export CGO_CXXFLAGS="${CXXFLAGS}"
@@ -55,15 +58,22 @@ build() {
     -W no-dev
     -D CMAKE_BUILD_TYPE=Release
     -D CMAKE_INSTALL_PREFIX=/usr
-    -D OLLAMA_LLAMA_BACKENDS="cuda_v13;rocm_v7_2;vulkan"
+    -D OLLAMA_LLAMA_BACKENDS="rocm_v7_2;vulkan"
     -D AMDGPU_TARGETS="$(rocm-supported-gfx)"
     # Sync GPU targets from CMakePresets.json
     # For CUDA 12
     # -D CMAKE_CUDA_ARCHITECTURES="50;52;53;60;61;62;70;72;75;80;86;87;89;90;90a"
     # for CUDA 13
-    -D CMAKE_CUDA_ARCHITECTURES="75;80;86;87;88;89;90;100;103;110;120;121;121-virtual"
+    # -D CMAKE_CUDA_ARCHITECTURES="75;80;86;87;88;89;90;100;103;110;120;121;121-virtual"
   )
 
+  # Disable GGML_CPU_ALL_VARIANTS on loongarch64; upstream llama.cpp b9479
+  # does not support it and aborts configure with FATAL_ERROR.
+  patch -Np1 -i "${srcdir}/disable-cpu-all-variants-loong64.patch"
+
+  install -Dm644 "${srcdir}/ggml-cpu-cpu_loongarch64.go" ml/backend/ggml/ggml/src/ggml-cpu/cpu_loongarch64.go
+  install -Dm644 "${srcdir}/ggml-cpu-arch-loongarch-loongarch.go" ml/backend/ggml/ggml/src/ggml-cpu/arch/loongarch/loongarch.go
+
   cmake "${cmake_options[@]}"
   cmake --build build
   go build .
@@ -79,9 +89,9 @@ check() {
 
 package_ollama() {
   cp -r ollama/staging-install/* "$pkgdir"
-  rm -r "$pkgdir/usr/lib/ollama/rocm"*
-  rm -r "$pkgdir/usr/lib/ollama/cuda"*
-  rm -r "$pkgdir/usr/lib/ollama/vulkan"*
+  rm -rf "$pkgdir/usr/lib/ollama/rocm"*
+  rm -rf "$pkgdir/usr/lib/ollama/cuda"*
+  rm -rf "$pkgdir/usr/lib/ollama/vulkan"*
 
   install -Dm755 $pkgname/ollama "$pkgdir/usr/bin/ollama"
   install -dm755 "$pkgdir/var/lib/ollama"
@@ -125,3 +135,13 @@ package_ollama-docs() {
   cp -r ollama/docs "$pkgdir/usr/share/doc/ollama"
   install -Dm644 ollama/LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
 }
+
+# Remove cuda
+pkgname=($(printf "%s\n" "${pkgname[@]}" | grep -Ev '^(ollama-cuda)$'))
+makedepends=($(printf "%s\n" "${makedepends[@]}" | grep -Ev '^(cuda)$'))
+source+=("disable-cpu-all-variants-loong64.patch"
+         "ggml-cpu-cpu_loongarch64.go"
+         "ggml-cpu-arch-loongarch-loongarch.go")
+b2sums+=('e658d1bd876f62e79e4bbb6d2463e1ad53194889d74a4926c833fa024539281eca3b4c8c913d36466f706969d31ef329ba1a1632cd7df0ff63cba9a49f671f07'
+         'b301ee36d80ada2cbe7a602ab57e2df962ad9d3f08874775f34e59325e91fe0b1ff70e7ee95b883ebf18e159e4f885d08e0c6d52d2a008e042472fa973e8dc2b'
+         '062f6d805f82de8ab68ded8bc245b662aceb524a930eaec59cd431a1c7207ec247dd0808d1493db5a196add3e5a80825899f3d4142392b47c7fcc0f42863d813')
