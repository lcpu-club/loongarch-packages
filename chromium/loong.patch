diff --git a/PKGBUILD b/PKGBUILD
index d9c69a6..0883b76 100644
--- a/PKGBUILD
+++ b/PKGBUILD
@@ -118,6 +118,20 @@ prepare() {
   # Increase _FORTIFY_SOURCE level to match Arch's default flags
   patch -Np1 -i ../increase-fortify-level.patch
 
+  # Patches for loong64
+  patch -Np1 -i "${srcdir}/loong64-fix-clang-builtins-path.diff"
+  patch -Np1 -i "${srcdir}/chromium-loongarch64-${_PATCHSET_LOONG}/chromium/"chromium-*-rollup.diff
+  patch -Np1 -i "${srcdir}/chromium-loongarch64-${_PATCHSET_LOONG}/chromium/"chromium-*-fix-invalid-substition-type.diff
+  for _patch in "${srcdir}/chromium-loongarch64-${_PATCHSET_LOONG}/chromium/"chromium-*-loongarch64*.diff; do
+    patch -Np1 -i $_patch
+  done
+  
+  # Add ` -mcmodel=medium` to CFLAGS etc.
+  # to avoid `relocation R_LARCH_B26 overflow`
+  export CFLAGS="${CFLAGS} -mcmodel=medium"
+  export CXXFLAGS="${CXXFLAGS} -mcmodel=medium"
+  export RUSTFLAGS="${RUSTFLAGS} -C code-model=medium"
+
   # Fixes for building with libstdc++ instead of libc++
 
   # Link to system tools required by the build
@@ -325,4 +339,11 @@ package() {
   install -Dm644 LICENSE "$pkgdir/usr/share/licenses/chromium/LICENSE"
 }
 
+depends+=(libyuv)
+_PATCHSET_LOONG="chromium-129.0.6668.68-1"
+source+=("https://github.com/AOSC-Dev/chromium-loongarch64/archive/refs/tags/${_PATCHSET_LOONG}.tar.gz"
+         "loong64-fix-clang-builtins-path.diff")
+sha256sums+=('bd2797ae4428975bd80bacb1c5671ced89756df8efb9c18aefb2374c892cae4d'
+             'f3da3e04b19163a329510a64e169035dc4915cad3a254919c55ec26751ee3c23')
+
 # vim:set ts=2 sw=2 et:
