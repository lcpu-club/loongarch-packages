--- a/PKGBUILD
+++ b/PKGBUILD
@@ -57,7 +57,7 @@ _gemname=google-protobuf
 
 prepare() {
   cd "$pkgname"
-  bazel --version
+#  bazel --version
 
   patch -p1 < ../protobuf-fix-build-type-none.patch # Fix cmake config compatibility mode
   patch -p1 < ../protobuf-33-patch-enum-traits-impl.patch
@@ -80,6 +80,7 @@ build() {
   cmake "${cmake_options[@]}"
   cmake --build build --verbose
 
+: <<'COMMENT_SEPARATOR'
   cd "$pkgbase"
   local bazel_options=()
 
@@ -91,6 +92,11 @@ build() {
   bazel build //python/dist:binary_wheel "${bazel_options[@]}"
 
   cd ruby
+COMMENT_SEPARATOR
+
+  cd "$pkgbase-7.$pkgver"
+  python -m build --wheel --no-isolation
+  cd ../"$pkgbase"/ruby
   local _gemdir="$(gem env gemdir)"
   local _gemver=4.$pkgver
   local _gemplatform=$(ruby -e "puts Gem::Platform.local")
@@ -172,7 +178,7 @@ package_python-protobuf() {
     'python'
   )
 
-  python -m installer --destdir="$pkgdir" "$pkgbase"/bazel-bin/python/dist/*.whl
+  python -m installer --destdir="$pkgdir" "$pkgbase-7.$pkgver"/dist/*.whl
   install -vDm 644 $pkgbase/LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
 }
 
@@ -190,3 +196,6 @@ package_ruby-google-protobuf() {
   install -vDm 644 $pkgbase/LICENSE -t "$pkgdir/usr/share/licenses/$pkgname/"
   install -Dm 0644 $pkgbase/ruby/*.md -t "$pkgdir/usr/share/doc/${pkgname}"
 }
+
+source+=("$pkgbase-$pkgver-python.tar.gz::https://files.pythonhosted.org/packages/source/${pkgbase::1}/${pkgbase//-/_}/${pkgbase//-/_}-7.$pkgver.tar.gz")
+sha512sums+=('SKIP')
