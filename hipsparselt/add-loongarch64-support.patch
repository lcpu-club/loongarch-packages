diff --git a/projects/hipsparselt/clients/include/hipsparselt_math.hpp b/projects/hipsparselt/clients/include/hipsparselt_math.hpp
index ed6159940ad..5f82b364354 100644
--- a/projects/hipsparselt/clients/include/hipsparselt_math.hpp
+++ b/projects/hipsparselt/clients/include/hipsparselt_math.hpp
@@ -30,7 +30,9 @@
 #include <cmath>
 #include <hip/hip_runtime.h>
 #include <hipsparselt/hipsparselt.h>
+#if defined(__x86_64__) || defined(__i386__)
 #include <immintrin.h>
+#endif
 #include <type_traits>
 
 /* ============================================================================================ */
@@ -40,6 +42,14 @@ inline __host__ hip_bfloat16 float_to_bfloat16_truncate(float val)
 {
 #if defined(__HIP_PLATFORM_AMD__)
     return hip_bfloat16(val, hip_bfloat16::truncate_t::truncate);
+#elif defined(__loongarch__) || defined(__loongarch64)
+    // Software truncation: take the upper 16 bits of the float (little-endian)
+    uint32_t bits;
+    memcpy(&bits, &val, sizeof(bits));
+    uint16_t bf16_bits = static_cast<uint16_t>(bits >> 16);
+    hip_bfloat16 result;
+    memcpy(&result, &bf16_bits, sizeof(bf16_bits));
+    return result;
 #else
     return __float2bfloat16_rd(val);
 #endif
@@ -69,6 +79,11 @@ inline hip_bfloat16 negate(hip_bfloat16 x)
 #if defined(__HIP_PLATFORM_AMD__)
     x.data ^= 0x8000;
     return x;
+#elif defined(__loongarch__) || defined(__loongarch64)
+    // Flip the sign bit (bit 15) via raw uint16_t access
+    uint16_t& raw = reinterpret_cast<uint16_t&>(x);
+    raw ^= 0x8000;
+    return x;
 #else
     auto raw = __nv_bfloat16_raw(x);
     raw.x ^= 0x8000;
