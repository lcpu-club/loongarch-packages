# LoongArch64-specific busybox config overrides
# Appended to the upstream x86_64 config during build() for loong64.

# x86 SHA-NI hardware acceleration is not available on LoongArch64.
# Disables sha1_process_block64_shaNI / sha256_process_block64_shaNI.
# CONFIG_SHA1_HWACCEL is not set
# CONFIG_SHA256_HWACCEL is not set

# i386-specific stack optimization, not applicable to LoongArch64.
# CONFIG_STACK_OPTIMIZATION_386 is not set

# Removed in busybox 1.37.0; left in the 1.36.1-based config for x86_64.
# CONFIG_ASH_SLEEP is not set

# The tc applet uses CBQ qdisc structures that were removed from modern
# kernel-headers-musl (e.g. TCA_CBQ_* / struct tc_cbq_*). Nix sandbox
# builds do not need traffic control, so disable the applet entirely.
# CONFIG_TC is not set
# CONFIG_FEATURE_TC_INGRESS is not set

# The loong64 musl toolchain's GCC spec injects -latomic_asneeded, but
# libatomic is not shipped with musl. Tell the driver not to link it.
CONFIG_EXTRA_CFLAGS="-fno-link-libatomic"
CONFIG_EXTRA_LDFLAGS="-fno-link-libatomic"
